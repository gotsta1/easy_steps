# ── App ─────────────────────────────────────────────────────────────────────
APP_ENV=dev
APP_HOST=0.0.0.0
APP_PORT=8000
# Public base URL used to register the Telegram webhook.
# For local dev use ngrok or similar: https://xxxx.ngrok-free.app
APP_PUBLIC_BASE_URL=https://your-app.up.railway.app

# ── Database ─────────────────────────────────────────────────────────────────
# Local docker-compose:
DATABASE_URL=postgresql://easysteps:easysteps@localhost:5432/easysteps
# Railway injects a URL that starts with postgres:// — the app rewrites it
# automatically to postgresql+asyncpg://.

# ── Access Bot (Telegram) ────────────────────────────────────────────────────
ACCESS_BOT_TOKEN=123456:ABC-DEF...
ACCESS_BOT_WEBHOOK_PATH=/tg/access/webhook
# Random secret string; set the same value in Telegram setWebhook call.
ACCESS_BOT_SECRET_TOKEN=change_me_random_secret

# ── Telegram channel ─────────────────────────────────────────────────────────
# Numeric channel ID (negative). Find it by forwarding a message to @userinfobot.
TG_CHANNEL_ID=-1001234567890
# Optional second channel for "menu" product. Keep 0 to disable.
TG_MENU_CHANNEL_ID=0

# ── Join window ──────────────────────────────────────────────────────────────
JOIN_WINDOW_SECONDS=600

# ── Kick on expire ───────────────────────────────────────────────────────────
KICK_ON_EXPIRE=false
KICK_GRACE_SECONDS=3600
KICK_CRON_SECONDS=3600

# ── Lava.top ─────────────────────────────────────────────────────────────────
LAVA_WEBHOOK_PATH=/lava/webhook
# Basic Auth credentials — you invent these yourself and enter the same
# values both here AND in the Lava dashboard webhook creation form.
LAVA_WEBHOOK_LOGIN=my_lava_login
LAVA_WEBHOOK_PASSWORD=my_lava_password
# API key from https://developers.lava.top
LAVA_API_KEY=change_me_lava_api_key

# Lava offer/product IDs for each club subscription duration.
# Copy the offer ID from your Lava dashboard for each digital product.
# Leave blank for products you haven't created yet — they'll be ignored.
LAVA_OFFER_CLUB_1M=          # → 30 days
LAVA_OFFER_CLUB_3M=          # → 90 days
LAVA_OFFER_CLUB_6M=          # → 180 days
LAVA_OFFER_CLUB_12M=         # → 365 days
LAVA_OFFER_MENU=             # → lifetime access to menu channel

# ── BotHelp API (expiry notifications) ──────────────────────────────────────
# OAuth2 client credentials from BotHelp account settings.
BOTHELP_CLIENT_ID=
BOTHELP_CLIENT_SECRET=
# Bot referral — identifier of your BotHelp bot (from bot settings page).
BOTHELP_BOT_REFERRAL=
# Step referrals for expiry notification messages (3/2/1 days before expiry).
# Leave blank to disable notifications for that threshold.
BOTHELP_STEP_NOTIFY_3D=
BOTHELP_STEP_NOTIFY_2D=
BOTHELP_STEP_NOTIFY_1D=
# Webhook path for receiving BotHelp subscriber events.
BOTHELP_WEBHOOK_PATH=/bothelp/webhook

# ── Admin ────────────────────────────────────────────────────────────────────
ADMIN_TOKEN=change_me_admin_token

# ── Observability ────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
# Optional — leave blank to disable Sentry.
SENTRY_DSN=
